{
  "name": "@muxiu1997/eslint-plugin",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.29.2",
  "description": "MuXiu1997's ESLint rules",
  "author": "MuXiu1997 <muxiu1997@muxiu1997.com> (https://github.com/MuXiu1997)",
  "license": "MIT",
  "homepage": "https://github.com/MuXiu1997/eslint-plugin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MuXiu1997/eslint-plugin.git"
  },
  "bugs": "https://github.com/MuXiu1997/eslint-plugin/issues",
  "keywords": [
    "eslint",
    "eslint-plugin"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./preset": {
      "types": {
        "import": "./dist/configs/preset.d.mts",
        "require": "./dist/configs/preset.d.cts"
      },
      "import": "./dist/configs/preset.mjs",
      "require": "./dist/configs/preset.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "preset": ["./dist/configs/preset.d.mts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint . --fix",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": "*"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.6.1",
    "@arethetypeswrong/core": "0.18.2",
    "@types/node": "25.2.0",
    "@typescript-eslint/parser": "8.56.1",
    "@typescript-eslint/utils": "8.56.1",
    "eslint": "9.39.2",
    "eslint-plugin-format": "2.0.1",
    "eslint-vitest-rule-tester": "3.1.0",
    "publint": "0.3.18",
    "tsdown": "0.20.3",
    "vitest": "4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
