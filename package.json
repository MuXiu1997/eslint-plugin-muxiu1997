{
  "name": "eslint-plugin-muxiu1997",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.29.2",
  "description": "MuXiu1997's ESLint rules",
  "author": "MuXiu1997 <muxiu1997@muxiu1997.com> (https://github.com/MuXiu1997)",
  "license": "MIT",
  "homepage": "https://github.com/muxiu1997/eslint-plugin-muxiu1997#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muxiu1997/eslint-plugin-muxiu1997.git"
  },
  "bugs": "https://github.com/muxiu1997/eslint-plugin-muxiu1997/issues",
  "keywords": [
    "eslint",
    "eslint-plugin"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint . --fix",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": "*"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.6.1",
    "@types/node": "25.2.0",
    "@typescript-eslint/parser": "8.56.1",
    "@typescript-eslint/utils": "8.56.1",
    "eslint": "9.39.2",
    "eslint-plugin-format": "2.0.1",
    "eslint-vitest-rule-tester": "3.1.0",
    "tsdown": "0.20.3",
    "vitest": "4.0.18"
  }
}
